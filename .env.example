# Django Settings
SECRET_KEY=use-a-strong-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# For PostgreSQL (recommended for production):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=content_mentor
# DB_USER=postgres
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=5432

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# Telegram Bot Configuration
# ⚠️ IMPORTANT: Bot token and nickname should ONLY be in database!
# Go to Admin Panel > Bot Settings to configure them
# DO NOT add TELEGRAM_TOKEN or TELEGRAM_NICKNAME here

# Bot API Base URL (for telegram bot to connect)
API_BASE_URL=http://localhost:8000/api

# WhatsApp Configuration (for future use)
# WHATSAPP_PHONE_NUMBER=+1234567890
# WHATSAPP_API_KEY=your_whatsapp_api_key
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token

# Logging
LOG_LEVEL=INFO

# Payment Gateway (for future use)
# STRIPE_PUBLIC_KEY=pk_test_xxx
# STRIPE_SECRET_KEY=sk_test_xxx
# PAYPAL_CLIENT_ID=xxx
# PAYPAL_SECRET=xxx
